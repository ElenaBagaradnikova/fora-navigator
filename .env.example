# Iteration 3 competition-only safety gate. Keep false for public use and any real data.
ENABLE_LIVE_AI=false

# Server-only OpenAI key. Never expose it with a NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=

# Approved runtime model. The MVP UI and contract tests target Terra only.
OPENAI_MODEL=gpt-5.6-terra

# Set to false to return a hard API error instead of the safe demo fallback.
ENABLE_DEMO_FALLBACK=true

# Protected monthly source-review reminder. Values stay server-side.
CRON_SECRET=
RESEND_API_KEY=
KNOWLEDGE_ALERT_EMAIL=
KNOWLEDGE_ALERT_FROM=

# Consultation is a non-sending demo by default. Real delivery requires the
# explicit flag and every server-only value below.
ENABLE_CONSULTATION_HANDOFF=false
CONSULTATION_EMAIL_TO=fora.disability@gmail.com
CONSULTATION_EMAIL_FROM=
CONSULTATION_RATE_LIMIT_SALT=
